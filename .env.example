# Docker Compose publishes the proxy on this host port
PORT=3456

# Bind to all interfaces so the native dashboard advertises LAN addresses.
# HOST=0.0.0.0

# Optional: local workspaces Claude Code may need to access inside the container
REPOS_DIR=/opt/repos

# Local command-surface ports
# OPEN_WEBUI_PORT=8080

# Claude CLI config paths (defaults to ~/.claude and ~/.claude.json)
# CLAUDE_CONFIG_DIR=/home/youruser/.claude
# CLAUDE_CONFIG_FILE=/home/youruser/.claude.json

# Optional: match the container user to your host user so Claude credentials
# mounted from your home directory stay readable.
# PUID=1000
# PGID=1000

# Default extended-thinking budget applied when the client does not send one.
# Accepts an integer (tokens) or one of: off, low, medium, high, xhigh, max.
# Use this when your client cannot pass thinking settings via the OpenAI API.
# DEFAULT_THINKING_BUDGET=high

# Optional: when the requested Claude model is unavailable, step down through
# these selectors in order. `default` follows Claude Code's account-tier
# recommendation; `haiku` is a common low-cost backup if your account exposes it.
# CLAUDE_PROXY_MODEL_FALLBACKS=default,haiku

# When running the proxy directly on the host, point structured logs at the
# repo's ignored logs directory so the native dashboard can tail them.
# CLAUDE_PROXY_LOG_FILE=logs/proxy.jsonl

# Optional: local Gemini CLI fallback. No API key required. The proxy runs the
# local `gemini` CLI in read-only plan mode from an isolated workdir.
#
# GEMINI_CLI_ENABLED=true
# GEMINI_CLI_COMMAND=/opt/homebrew/bin/gemini
# GEMINI_CLI_MODEL=gemini-2.5-pro
# GEMINI_CLI_EXTRA_MODELS=gemini-2.5-flash
# GEMINI_CLI_WORKDIR=/tmp/claude-max-api-proxy-gemini-cli
#
# Optional: external OpenAI-compatible provider. Claude remains the default;
# these providers are opt-in and only activate when you explicitly request the
# external model ID.
#
# Gemini auto-config:
# GEMINI_API_KEY=your-google-ai-studio-key
# GOOGLE_API_KEY=your-google-ai-studio-key
#
# Z.AI / GLM auto-config:
# ZAI_API_KEY=your-z-ai-key
# BIGMODEL_API_KEY=your-z-ai-key
# ZAI_MODEL=glm-4.7-flash
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_CODING_PLAN=false
#
# Generic provider override:
# OPENAI_COMPAT_FALLBACK_PROVIDER=google
# OPENAI_COMPAT_FALLBACK_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_COMPAT_FALLBACK_API_KEY=your-google-ai-studio-key
# OPENAI_COMPAT_FALLBACK_MODEL=gemini-2.5-flash
# OPENAI_COMPAT_FALLBACK_STREAM_MODE=synthetic

# Open WebUI defaults to the local proxy. If you want Open WebUI to request the
# configured external model through this proxy, set:
# OPEN_WEBUI_TASK_MODEL_EXTERNAL=gemini-2.5-flash
#
# If you want Open WebUI to point directly at another provider instead, override:
# OPEN_WEBUI_OPENAI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPEN_WEBUI_OPENAI_API_KEY=your-google-ai-studio-key
# OPEN_WEBUI_TASK_MODEL_EXTERNAL=gemini-2.5-flash

# Optional: enable the mutable /admin/thinking-budget endpoint.
# Disabled by default because the proxy does not authenticate clients.
# CLAUDE_PROXY_ENABLE_ADMIN_API=false
